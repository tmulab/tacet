{
  "name": "tacet",
  "version": "0.1.0",
  "private": true,
  "description": "TACET — two undecided readers audit a scientific dispute. Research engine from The Machine Unconscious (TMU).",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "demo:replay": "tsc -p tsconfig.build.json && node dist/pipeline/run-replay.js",
    "build:fixture": "node --use-system-ca --import tsx src/ingestion/build-ingested-fixture.ts",
    "protocol": "node --use-system-ca --import tsx --env-file-if-exists=.env src/protocol/prepare.ts",
    "protocol:harvest": "node --use-system-ca --import tsx --env-file-if-exists=.env src/protocol/harvest-from-protocol.ts",
    "protocol:coverage": "node --import tsx src/protocol/coverage-audit.ts",
    "harvest": "node --use-system-ca --import tsx --env-file-if-exists=.env src/ingestion/harvest.ts",
    "summarize": "node --use-system-ca --import tsx --env-file-if-exists=.env src/ingestion/summarize.ts",
    "read": "node --use-system-ca --import tsx --env-file-if-exists=.env src/ingestion/read.ts",
    "freeze": "node --use-system-ca --import tsx src/pipeline/freeze-fixture.ts",
    "narrate": "node --use-system-ca --import tsx --env-file-if-exists=.env src/pipeline/narrate.ts",
    "baseline": "node --use-system-ca --import tsx --env-file-if-exists=.env src/pipeline/baseline-deepresearch.ts",
    "compare-uplift": "node --use-system-ca --import tsx --env-file-if-exists=.env src/pipeline/compare-uplift.ts",
    "compare-anchors": "node --import tsx src/pipeline/compare-anchors.ts",
    "mutation": "stryker run",
    "build:html": "node scripts/build-html.mjs",
    "llm:check": "node --use-system-ca --import tsx --env-file-if-exists=.env src/ingestion/llm-check.ts"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^22.0.0",
    "fast-check": "^4.8.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "unpdf": "^1.6.2"
  }
}
