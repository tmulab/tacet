{
  "name": "tacet",
  "version": "0.1.0",
  "private": true,
  "description": "TACET — two undecided readers audit a scientific dispute. Research engine from The Machine Unconscious (TMU).",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "demo:replay": "tsx src/pipeline/run-replay.ts",
    "build:fixture": "tsx src/ingestion/build-ingested-fixture.ts",
    "harvest": "tsx --env-file-if-exists=.env src/ingestion/harvest.ts",
    "summarize": "tsx --env-file-if-exists=.env src/ingestion/summarize.ts",
    "read": "tsx --env-file-if-exists=.env src/ingestion/read.ts",
    "llm:check": "tsx --env-file-if-exists=.env src/ingestion/llm-check.ts"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
