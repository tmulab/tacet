# TACET — example environment. Copy to .env and fill for `live` mode only.
# `replay` mode (the judge's default) needs NONE of these.

# Model backend for LlmReader (live mode only). Roles, not brands:
# any capable model works. Free open-weights default documented in README.
TACET_MODEL_ENDPOINT=
TACET_MODEL_KEY=
TACET_MODE=replay

# Live-mode gate (E3-AUTH). A single strong secret that the live endpoint (the
# one that spends LLM) checks SERVER-SIDE before any token is spent — compared
# timing-safely (crypto.timingSafeEqual). Give it to the judge with the
# submission; the door stays closed for the rest. FAIL-CLOSED: if this is unset,
# the live endpoint returns 503 and runs no model. Replay/home need it NOT — they
# are offline and stay open. NEVER commit a real value; server env only.
TACET_LIVE_SECRET=

# Step-0 ("passo 0"): `npm run protocol -- propose "question?"` distils a raw
# question into a versioned investigation protocol BEFORE any harvest. With a key
# it asks a model for a FIRST DRAFT (two-clause SAGO hypothesis + descriptors +
# criteria + seed papers) over the SAME OpenRouter cascade as summarize; with NO
# key it degrades to an empty human form (proposedBy=human, never fabricated).
# Nothing becomes the referenceHypothesis without explicit human acceptance,
# enforced offline by `npm run protocol -- accept <draft.json>`. Reuses
# SUMMARY_API_KEY/OPENROUTER_API_KEY/SUMMARY_MODEL below — no new vars.

# Contact e-mail for the Crossref polite pool, used ONLY by `npm run harvest`
# (the only network path; never touched by replay or tests). Not hardcoded.
TACET_CONTACT_EMAIL=

# Shared reference hypothesis both readers anchor to (Phase 5c). Written into the
# corpus by `npm run harvest` and carried through to `npm run read`, where it is
# injected into BOTH readers' system prompt — the doubt lives in this anchor, not
# in a persona. Per-case (not hardcoded); defaults to the SARS-CoV-2 origin case
# in the SAGO formulation (WHO 2025). Set this to anchor a different case.
TACET_REFERENCE_HYPOTHESIS=

# LLM summarizer (Phase 5a), used ONLY by `npm run summarize` — never by replay
# or tests. Without a key, the corpus keeps the deterministic truncated-stub.
# Default endpoint is OpenRouter with a free open-weights model.
SUMMARY_BASE=https://openrouter.ai/api/v1
SUMMARY_MODEL=openai/gpt-oss-20b:free
OPENROUTER_API_KEY=
# Alternative endpoint (e.g. a local vLLM server), same OpenAI-compatible shape:
# point SUMMARY_BASE at it and set SUMMARY_API_KEY (takes precedence over OPENROUTER).
# e.g. SUMMARY_BASE=http://localhost:8000/v1  SUMMARY_MODEL=<local-model>
SUMMARY_API_KEY=

# Two independent readers (Phase 5b), used ONLY by `npm run read` — never by
# replay or tests. Divergence must come from MODEL INDEPENDENCE (different
# companies), not opposed instructions. ALL free via OpenRouter, but from
# distinct companies: reader A = NVIDIA Nemotron-nano, reader B = OpenAI
# gpt-oss-120b. READER_A/B/FALLBACK_MODEL select slots A, B and the reserve C
# (must be distinct companies — validated at runtime); every OTHER model in
# FREE_MODELS (src/llm/openrouter.ts) becomes the tail of the reserve pool, run
# as a cascade with retry+backoff. Each reader's key falls back to
# OPENROUTER_API_KEY if its own is unset. (Queue ranked by bench/free-model-bench.mjs.)
READER_A_BASE=https://openrouter.ai/api/v1
READER_A_MODEL=nvidia/nemotron-3-nano-30b-a3b:free
READER_A_API_KEY=
READER_B_BASE=https://openrouter.ai/api/v1
READER_B_MODEL=openai/gpt-oss-120b:free
READER_B_API_KEY=
# Fallback reader (Google Gemma, free via OpenRouter — a THIRD company): runs
# ONLY to fill a slot whose primary failed on a claim — never a tiebreaker for
# genuine A-vs-B disagreement. Rate-limited in volume; backoff recommended.
READER_FALLBACK_BASE=https://openrouter.ai/api/v1
READER_FALLBACK_MODEL=google/gemma-4-26b-a4b-it:free
READER_FALLBACK_API_KEY=
