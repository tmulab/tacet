# TACET — example environment. Copy to .env and fill for `live` mode only.
# `replay` mode (the judge's default) needs NONE of these.

# Model backend for LlmReader (live mode only). Roles, not brands:
# any capable model works. Free open-weights default documented in README.
TACET_MODEL_ENDPOINT=
TACET_MODEL_KEY=
TACET_MODE=replay

# Contact e-mail for the Crossref polite pool, used ONLY by `npm run harvest`
# (the only network path; never touched by replay or tests). Not hardcoded.
TACET_CONTACT_EMAIL=

# Shared reference hypothesis both readers anchor to (Phase 5c). Written into the
# corpus by `npm run harvest` and carried through to `npm run read`, where it is
# injected into BOTH readers' system prompt — the doubt lives in this anchor, not
# in a persona. Per-case (not hardcoded); defaults to the SARS-CoV-2 origin case
# in the SAGO formulation (WHO 2025). Set this to anchor a different case.
TACET_REFERENCE_HYPOTHESIS=

# LLM summarizer (Phase 5a), used ONLY by `npm run summarize` — never by replay
# or tests. Without a key, the corpus keeps the deterministic truncated-stub.
# Default endpoint is OpenRouter with a free open-weights model.
SUMMARY_BASE=https://openrouter.ai/api/v1
SUMMARY_MODEL=openai/gpt-oss-20b:free
OPENROUTER_API_KEY=
# Alternative endpoint (local vLLM / Z.AI), same OpenAI-compatible shape: point
# SUMMARY_BASE at it and set SUMMARY_API_KEY (takes precedence over OPENROUTER).
# e.g. SUMMARY_BASE=http://localhost:8000/v1  SUMMARY_MODEL=<local-model>
SUMMARY_API_KEY=

# Two independent readers (Phase 5b), used ONLY by `npm run read` — never by
# replay or tests. Divergence must come from MODEL INDEPENDENCE (different
# companies), not opposed instructions. Reader A defaults to GLM (Z.AI), reader
# B to MiniMax (via OpenRouter). Each reader's key falls back to an existing key
# if its own is unset (A→SUMMARY_API_KEY/ZAI_API_KEY, B→OPENROUTER_API_KEY).
READER_A_BASE=https://api.z.ai/api/coding/paas/v4
READER_A_MODEL=glm-4.6
READER_A_API_KEY=
READER_B_BASE=https://openrouter.ai/api/v1
READER_B_MODEL=minimax/minimax-m2.7
READER_B_API_KEY=
# Fallback reader (Google Gemma, OpenRouter): runs ONLY to fill a slot whose
# primary failed on a claim — never a tiebreaker for genuine A-vs-B disagreement.
READER_FALLBACK_BASE=https://openrouter.ai/api/v1
READER_FALLBACK_MODEL=google/gemma-4-31b-it:free
READER_FALLBACK_API_KEY=
